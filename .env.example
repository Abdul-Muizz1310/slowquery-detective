# ---------------------------------------------------------------------------
# slowquery-detective — environment variables
# ---------------------------------------------------------------------------
# This package is a library. It reads its own config from pydantic-settings,
# but the vars below are the ones a host application should forward when it
# calls `slowquery_detective.install(app, engine, ...)`.
#
# Copy to `.env` for local development; never commit `.env`.
# ---------------------------------------------------------------------------

# --- Slow-query detection -------------------------------------------------
# Queries slower than this (in ms) are flagged and pushed onto the EXPLAIN
# queue. 100ms is a reasonable starting point for web workloads.
SLOWQUERY_THRESHOLD_MS=100

# Fraction of queries to sample for fingerprinting (0.0–1.0). 1.0 = every
# query. Drop this on very high-QPS services to bound overhead.
SLOWQUERY_SAMPLE_RATE=1.0

# Where to persist fingerprints, samples, plans, and suggestions. Typically
# the same DATABASE_URL as the host app, but can be split onto a dedicated
# Neon branch (e.g. `slowquery`) to keep telemetry out of app traffic.
SLOWQUERY_STORE_URL=postgresql+asyncpg://user:password@host/db

# --- LLM fallback (optional) ----------------------------------------------
# When the rules engine returns no suggestion, fall back to an LLM. Disabled
# by default. Set to `true` to enable.
LLM_FALLBACK_ENABLED=false

# OpenRouter credentials. The `openai` client is configured with
# `base_url=OPENROUTER_BASE_URL`. See muizz-lab memory for model picks.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_PRIMARY=nvidia/nemotron-nano-9b-v2:free
OPENROUTER_MODEL_FAST=google/gemma-3-27b-it:free
OPENROUTER_MODEL_FALLBACK=z-ai/glm-4.5-air:free
